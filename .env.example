# ─────────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored — NEVER commit it.
# `.env.example` holds NO real values and is the only env file that is tracked.
# ─────────────────────────────────────────────────────────────────────────

# Deployer signing.
#  - PRODUCTION: leave PRIVATE_KEY EMPTY. Sign with an encrypted keystore or a
#    hardware wallet instead, so no plaintext key ever lives on disk:
#       cast wallet import totoDeployer --interactive      # one-time
#       forge script ... --account totoDeployer --broadcast # per deploy
#    (or --ledger / --trezor for a hardware wallet)
#  - TESTNET ONLY: you may set a throwaway key here for convenience. Never put a
#    key that holds real funds or owns the production contract in plaintext.
PRIVATE_KEY=

# Chainlink VRF v2.5 subscription id (fund it with LINK).
VRF_SUB_ID=

# Address that receives the per-draw treasury fee. For production use a multisig.
TREASURY=

# RPC endpoint used by forge scripts (server-side only, never shipped to users).
SEPOLIA_RPC_URL=

# Used only by RedeployToto.s.sol when reusing an existing USDC.
# MOCK_USDC_ADDRESS=

# Used only by TransferOwnership.s.sol — the multisig that should own the contract.
# NEW_OWNER=
# TOTO_ADDRESS=
