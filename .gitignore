# ───────────────────────── SECRETS — NEVER COMMIT ─────────────────────────
# Plaintext keys / RPC / API keys live here. Keep ONLY .env.example tracked.
.env
.env.*
!.env.example
*.key
*.pem
keystore/
*.keystore
mnemonic*

# ───────────────────────── Foundry / Solidity ─────────────────────────
out/
cache/
# broadcast/ contains deployment tx data (addresses, args) — keep private.
# NOTE: comments MUST be on their own line; a trailing "# ..." would become
# part of the pattern and silently disable it.
broadcast/
.gas-snapshot
# Dependencies — install with `forge install`, not tracked in the repo.
lib/
# Deploy scripts — kept local, not published.
script/

# ───────────────────────── Private / security ─────────────────────────
# Unfixed vulnerability write-ups — must not be published while live.
BulgarianToto-findings.md

# ───────────────────────── Frontend (Node / Vite) ─────────────────────────
node_modules/
frontend/node_modules/
# build artifact — regenerate with `npm run build`
frontend/dist/
*.tsbuildinfo
.vite/

# Local Foundry keystores (if you import a deployer key for `forge --account`)
*.json.keystore
.foundry/keystores/

# ───────────────────────── Python venv / misc ─────────────────────────
.venv/
__pycache__/
*.pyc

