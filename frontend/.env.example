# ─────────────────────────────────────────────────────────────────────────
# ⚠️  PUBLIC BY DESIGN. Vite inlines every VITE_* variable into the JavaScript
#     bundle that ships to the browser. Anything you put here is readable by
#     ANY visitor (view-source / devtools). NEVER put a secret, private key, or
#     admin credential in a VITE_* variable. Secrets belong in the root .env
#     used by forge scripts — never in the frontend.
# ─────────────────────────────────────────────────────────────────────────

# Target chain — 1 = Ethereum mainnet (real USDC), 11155111 = Sepolia.
# Defaults to Sepolia when unset.
VITE_CHAIN_ID=11155111

# On-chain contract address — public.
VITE_CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# Block the contract was deployed at (bounds eth_getLogs scans, e.g. leaderboard).
# Set this to the deployment block printed by the deploy script / shown on Etherscan.
VITE_DEPLOY_BLOCK=0

# WalletConnect project id — designed to be a public client identifier.
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Comma-separated Sepolia RPC endpoints (highest priority first).
# REQUIRED FOR SCALE: public RPCs rate-limit and will not survive heavy traffic.
#
# ⚠️  A raw Alchemy/Infura key placed here is PUBLIC and can be extracted from
#     the bundle and abused (your quota, your bill). Use ONE of:
#       1. A key locked to your domain (allow-list referrers in the provider UI), or
#       2. Your own thin RPC proxy that holds the key server-side and only
#          forwards eth_* reads. Point VITE_RPC_URLS at the proxy, not the key.
#     If unset, the app falls back to a list of public endpoints (dev only).
# VITE_RPC_URLS=https://your-proxy.example.com/rpc
